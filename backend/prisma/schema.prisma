// =====================================================
// Prisma Schema: FinLearn Backend
// Only tables the backend actually uses: ApiCache, ApiUsageDaily
// =====================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// =========================
// API Cache (persistent, TTL-based)
// =========================

model ApiCache {
  key       String   @id                  // e.g. "fmp:profile:AAPL"
  provider  String                        // fmp, finnhub, twelvedata
  dataType  String   @map("data_type")    // profile, quote, financials, history, news, technicals, search, metrics, full
  symbol    String?                       // stock symbol (nullable for non-symbol queries)
  data      Json                          // cached JSON response
  expiresAt DateTime @map("expires_at")   // when this entry becomes stale
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([provider, dataType])
  @@index([symbol])
  @@index([expiresAt])
  @@map("api_cache")
}

// =========================
// API Usage Tracking (daily counters per provider)
// =========================

model ApiUsageDaily {
  provider   String    @map("provider")
  date       DateTime  @db.Date
  callCount  Int       @default(0) @map("call_count")
  dailyLimit Int       @map("daily_limit")
  lastCallAt DateTime? @map("last_call_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@id([provider, date])
  @@map("api_usage_daily")
}
