# ============================================
# FinLearn Environment Variables
# Copy this file to .env and fill in your values
# ============================================
#
# ⚠️  PRODUCTION CHECKLIST:
#   1. Generate NEXTAUTH_SECRET:  openssl rand -hex 32
#   2. Generate ADMIN_API_KEY:    openssl rand -hex 32
#   3. Set NODE_ENV=production
#   4. Set real DATABASE_URL (with SSL: ?sslmode=require)
#   5. Set real domain URLs (NEXTAUTH_URL, FRONTEND_URL, NEXT_PUBLIC_SITE_URL)
#   6. Configure SMTP for email verification
#   7. Run: npx prisma migrate deploy
#

# ── Database ──
DATABASE_URL="postgresql://user:password@localhost:5432/finlearn"

# ── Backend API Keys (free tiers available) ──
FMP_API_KEY=your_fmp_key              # https://financialmodelingprep.com/
FINNHUB_API_KEY=your_finnhub_key      # https://finnhub.io/
TWELVE_DATA_API_KEY=your_12data_key   # https://twelvedata.com/

# ── Backend Server ──
PORT=4000
NODE_ENV=development                  # ⚠️ set to 'production' on server
FRONTEND_URL=http://localhost:3000    # ⚠️ set to https://your-domain.com

# ── Admin (protects /api/health/usage|cache endpoints) ──
ADMIN_API_KEY=generate_a_random_secret_here   # ⚠️ openssl rand -hex 32

# ── NextAuth (frontend) ──
NEXTAUTH_SECRET=generate_a_random_secret_here  # ⚠️ openssl rand -hex 32
NEXTAUTH_URL=http://localhost:3000             # ⚠️ set to https://your-domain.com

# ── Site URL (used for SEO, OG tags, sitemap) ──
NEXT_PUBLIC_SITE_URL=http://localhost:3000     # ⚠️ set to https://your-domain.com

# ── Google OAuth (optional — app works without it) ──
GOOGLE_CLIENT_ID=your_google_client_id        # https://console.cloud.google.com/
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Frontend → Backend URL ──
NEXT_PUBLIC_API_URL=http://localhost:4000      # ⚠️ set to https://api.your-domain.com

# ── Email (SMTP) ── required for email verification & forgot password
# Gmail example:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=yourname@gmail.com
#   SMTP_PASS=your-app-password   (Gmail → Settings → Security → App passwords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="FinLearn <noreply@your-domain.com>"
