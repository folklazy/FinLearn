# ============================================
# FinLearn Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# ── Database ──
DATABASE_URL="postgresql://user:password@localhost:5432/finlearn"

# ── Backend API Keys (free tiers available) ──
FMP_API_KEY=your_fmp_key              # https://financialmodelingprep.com/
FINNHUB_API_KEY=your_finnhub_key      # https://finnhub.io/
TWELVE_DATA_API_KEY=your_12data_key   # https://twelvedata.com/

# ── Backend Server ──
PORT=4000
NODE_ENV=development                  # set to 'production' on server
FRONTEND_URL=http://localhost:3000

# ── Admin (protects /api/health/usage|cache endpoints) ──
ADMIN_API_KEY=generate_a_random_secret_here   # openssl rand -hex 32

# ── NextAuth (frontend) ──
NEXTAUTH_SECRET=generate_a_random_secret_here  # openssl rand -hex 32
NEXTAUTH_URL=http://localhost:3000

# ── Google OAuth (optional) ──
GOOGLE_CLIENT_ID=your_google_client_id        # https://console.cloud.google.com/
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Frontend → Backend URL ──
NEXT_PUBLIC_API_URL=http://localhost:4000

# ── Email (optional, for verification emails) ──
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
